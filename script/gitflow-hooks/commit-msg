#!/bin/bash
# GitFlow 规范检查脚本
# 必须在 .git/hooks 目录创建对应软链接才能生效

echo "=== GitFlow 提交规范检查 ==="

# 获取当前分支名
BRANCH=$(git symbolic-ref --short HEAD 2>/dev/null)
COMMIT_MSG=$(cat "$1")

echo "分支: $BRANCH"

# 检查分支命名规范
case "$BRANCH" in
    feature/*|bugfix/*|hotfix/*|release/*|develop|main)
        echo "✓ 分支名符合规范"
        ;;
    *)
        echo "✗ 分支名不符合规范"
        echo "  期望格式: feature/*, bugfix/*, hotfix/*, release/*, develop, main"
        exit 1
        ;;
esac

# 检查提交信息格式
if [[ ! "$COMMIT_MSG" =~ ^[a-z]+\(:\).+ ]]; then
    echo "✗ Commit 消息不符合 Conventional Commits 规范"
    echo "  期望格式: <type>(<scope>): <subject>"
    echo "  示例: feat(article): 添加文章CRUD接口"
    echo "  类型: feat, fix, docs, style, refactor, perf, test, chore"
    exit 1
fi

echo "✓ Commit 消息符合规范"
echo "================================"
