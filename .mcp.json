{
  "mcpServers": {
    "antd-components": {
      "command": "cmd",
      "args": ["/c", "npx", "-y", "@jzone-mcp/antd-components-mcp"]
    },
    "chrome-devtools": {
      "command": "cmd",
      "args": ["/c", "npx", "-y", "chrome-devtools-mcp", "--isolated"]
    },
    "mysql": {
      "command": "cmd",
      "args": ["/c", "npx", "-y", "mysql-mcp-server"],
      "env": {
        "MYSQL_HOST": "localhost",
        "MYSQL_PORT": "3306",
        "MYSQL_USER": "root",
        "MYSQL_PASSWORD": "root",
        "MYSQL_DATABASE": "sidifensen_blog"
      }
    },
    "ssh": {
      "command": "cmd",
      "args": ["/c", "npx", "-y", "@fangjunjie/ssh-mcp-server", "--config-file", "C:\\Users\\x\\ssh-config.json"]
    }
  }
}
