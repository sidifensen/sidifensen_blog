{
  "mcpServers": {
    "mysql": {
      "command": "cmd",
      "args": ["/c", "npx", "-y", "@berthojoris/mcp-mysql-server", "mysql://root:root@localhost:3306/sidifensen_blog"]
    },
    "ssh": {
      "command": "cmd",
      "args": ["/c", "npx", "-y", "@fangjunjie/ssh-mcp-server", "--config-file", "C:\\Users\\x\\ssh-config.json"]
    },
    "redis": {
      "command": "cmd",
      "args": [
        "/c",
        "npx",
        "-y",
        "@modelcontextprotocol/server-redis",
        "redis://default:redis@localhost:6379/0"
      ]
    },
    "chrome-devtools": {
      "command": "cmd",
      "args": ["/c", "npx", "-y", "chrome-devtools-mcp"]
    }
  }
}
