{
  "mcpServers": {
    "antd-components": {
      "command": "cmd",
      "args": ["/c", "npx", "-y", "@jzone-mcp/antd-components-mcp"]
    },
    "chrome-devtools": {
      "command": "cmd",
      "args": ["/c", "npx", "-y", "chrome-devtools-mcp", "--isolated"]
    },
    "mysql": {
      "command": "cmd",
      "args": ["/c", "npx", "-y", "@berthojoris/mcp-mysql-server", "mysql://root:root@localhost:3306/sidifensen_blog"]
    },
    "ssh": {
      "command": "cmd",
      "args": ["/c", "npx", "-y", "@fangjunjie/ssh-mcp-server", "--config-file", "C:\\Users\\x\\ssh-config.json"]
    }
  }
}
