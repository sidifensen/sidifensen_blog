{
  "mcpServers": {
    "antd-components": {
      "command": "cmd",
      "args": ["/c", "npx", "-y", "@jzone-mcp/antd-components-mcp"]
    },
    "chrome-devtools": {
      "command": "cmd",
      "args": ["/c", "npx", "-y", "chrome-devtools-mcp", "--isolated"]
    },
    "mysql": {
      "command": "cmd",
      "args": ["/c", "npx", "-y", "@modelcontextprotocol/server-mysql", "--host", "localhost", "--port", "3306", "--user", "root", "--password", "root", "--database", "sidifensen_blog"]
    },
    "ssh": {
      "command": "cmd",
      "args": ["/c", "npx", "-y", "@fangjunjie/ssh-mcp-server", "--config-file", "C:\\Users\\x\\ssh-config.json"]
    }
  }
}
