{
  "mcpServers": {
    "mysql": {
      "command": "cmd",
      "args": ["/c", "npx", "-y", "@berthojoris/mcp-mysql-server", "mysql://root:root@localhost:3306/sidifensen_blog"]
    },
    "ssh": {
      "command": "cmd",
      "args": ["/c", "npx", "-y", "@fangjunjie/ssh-mcp-server", "--config-file", "C:\\Users\\x\\ssh-config.json"]
    },
    "chrome-devtools": {
      "command": "npx",
      "args": ["-y", "chrome-devtools-mcp@latest", "--autoConnect"]
    }
  }
}
