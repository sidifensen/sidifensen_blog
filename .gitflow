[gitflow]
# GitFlow 配置
# 使用方法: git flow init 或手动应用此配置

# 分支名称前缀
[gitflow "branch"]
    master = main
    develop = develop
    feature = feature/
    release = release/
    hotfix = hotfix/
    support = support/
    versiontag = v

# 前缀配置
[gitflow "prefix"]
    feature = feature/
    bugfix = bugfix/
    release = release/
    hotfix = hotfix/
    support = support/
    versiontag = v

# Hook 配置
[gitflow "hook"]
    pre-commit = scripts/pre-commit.sh

# 其他配置
[gitflow "path"]
    hooks = .git/hooks
