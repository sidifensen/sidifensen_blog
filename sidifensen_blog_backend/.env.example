# ========================================
# Sidifensen Blog 后端环境变量配置示例
# ========================================
# ⚠️ 注意：此文件为配置模板，不包含真实敏感信息
#
# 使用说明：
# 1. 复制此文件为 .env：cp .env.example .env
# 2. 根据您的实际环境修改下面的配置
# 3. 生产环境请务必修改所有默认密码和密钥
#
# ========================================

# ========================================
# 数据库配置 (MySQL)
# ========================================
# MYSQL_HOST=localhost
# MYSQL_PORT=3306
# MYSQL_DATABASE=sidifensen_blog
# MYSQL_USERNAME=root
# MYSQL_PASSWORD=root

# ========================================
# Redis 配置
# ========================================
# REDIS_HOST=localhost
# REDIS_PORT=6379
# REDIS_USERNAME=
# REDIS_PASSWORD=

# ========================================
# RabbitMQ 配置
# ========================================
RABBITMQ_HOST=localhost
RABBITMQ_PORT=5672
RABBITMQ_USERNAME=guest
RABBITMQ_PASSWORD=guest

# ========================================
# AI 服务配置 (DeepSeek API) - 必填
# ========================================
# 获取方式：https://platform.deepseek.com/api_keys
SPRING_AI_OPENAI_API_KEY=your-deepseek-api-key
SPRING_AI_OPENAI_BASE_URL=https://api.deepseek.com
SPRING_AI_OPENAI_CHAT_OPTIONS_MODEL=deepseek-chat

# ========================================
# MinIO 配置
# ========================================
MINIO_ENDPOINT=http://localhost:9000
MINIO_PUBLIC_POINT=http://localhost:9000
MINIO_ACCESS_KEY=minio
MINIO_SECRET_KEY=minio123456

# ========================================
# 邮件配置 (QQ 邮箱)
# ========================================
MAIL_USERNAME=your-email@qq.com
MAIL_PASSWORD=your-email-password

# ========================================
# JWT 密钥 - 生产环境请使用复杂随机字符串
# ========================================
SIDIFENSEN_JWT_SECRET=your_jwt_secret_key

# ========================================
# OAuth 第三方登录配置 (可选)
# ========================================
GITEE_CLIENT_ID=your-gitee-client-id
GITEE_CLIENT_SECRET=your-gitee-client-secret
GITEE_REDIRECT_URI=http://localhost:5000/oauth/gitee/callback

GITHUB_CLIENT_ID=your-github-client-id
GITHUB_CLIENT_SECRET=your-github-client-secret
GITHUB_REDIRECT_URI=http://localhost:5000/oauth/github/callback

QQ_CLIENT_ID=your-qq-client-id
QQ_CLIENT_SECRET=your-qq-client-secret
QQ_REDIRECT_URI=http://localhost:5000/oauth/qq/callback

# ========================================
# 阿里云内容审核 (可选)
# ========================================
ALIYUN_ACCESS_KEY_ID=your-access-key-id
ALIYUN_ACCESS_KEY_SECRET=your-access-key-secret

# ========================================
# 前端地址
# ========================================
FRONTEND_USER_HOST=http://localhost:7000/
FRONTEND_ADMIN_HOST=http://localhost:8000/

# ========================================
# 自动审核配置
# ========================================
SIDIFENSEN_PHOTO_AUTO_AUDIT=false
SIDIFENSEN_ARTICLE_AUTO_AUDIT=false
SIDIFENSEN_COMMENT_AUTO_AUDIT=false

# ========================================
# 支付宝支付配置 (VIP 会员)
# ========================================
# 支付宝应用 ID（在支付宝开放平台创建应用后获取）
VIP_ALIPAY_APP_ID=your-app-id
# 支付宝应用私钥（RSA2 私钥，需与支付宝开放平台配置一致）
VIP_ALIPAY_PRIVATE_KEY=your-private-key
# 支付宝公钥（从支付宝开放平台获取）
VIP_ALIPAY_PUBLIC_KEY=your-alipay-public-key
# 支付宝网关地址（沙箱环境：https://openapi-sandbox.dl.alipaydev.com/gateway.do，生产环境：https://openapi.alipay.com/gateway.do）
VIP_ALIPAY_GATEWAY_URL=https://openapi-sandbox.dl.alipaydev.com/gateway.do
# 异步通知地址（支付宝会向此地址发送支付结果通知）
VIP_ALIPAY_NOTIFY_URL=http://localhost:5000/vip/pay/alipay/notify
# 同步返回地址（PC 端支付成功后跳回）
VIP_ALIPAY_RETURN_URL_PC=http://localhost:7000/vip/result
# 同步返回地址（H5 支付成功后跳回）
VIP_ALIPAY_RETURN_URL_H5=http://localhost:7000/vip/result
# 是否使用沙箱环境（true=沙箱，false=生产）
VIP_ALIPAY_SANDBOX=true
