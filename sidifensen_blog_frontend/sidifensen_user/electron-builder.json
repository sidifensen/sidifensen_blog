{
  "appId": "com.sidifensen.blog.reader",
  "productName": "Sidifensen Blog",
  "asar": false,
  "directories": {
    "output": "electron/dist-electron"
  },
  "files": [
    "dist/**/*",
    "electron/**/*.js",
    "electron/**/*.cjs",
    "public/**/*"
  ],
  "win": {
    "target": [
      {
        "target": "nsis",
        "arch": ["x64"]
      }
    ],
    "artifactName": "${productName}-${version}-Setup.${ext}",
    "signAndEditExecutable": false
  },
  "nsis": {
    "oneClick": false,
    "allowToChangeInstallationDirectory": true
  },
  "mac": {
    "target": ["dmg"],
    "artifactName": "${productName}-${version}.${ext}"
  },
  "linux": {
    "target": ["AppImage"],
    "artifactName": "${productName}-${version}.${ext}"
  },
  "publish": {
    "provider": "github",
    "owner": "your-github-username",
    "repo": "sidifensen-blog"
  }
}
