{
  "name": "sidifensen_blog_frontend",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "description": "Sidifensen Blog Reader - Electron Desktop App",
  "author": "Sidifensen",
  "main": "electron/main.js",
  "scripts": {
    "dev": "vite",
    "build": "vite build",
    "preview": "vite preview",
    "test": "vitest",
    "test:run": "vitest run",
    "dev:electron": "vite --mode electron",
    "build:electron": "vite build --mode electron",
    "electron:dev": "concurrently -k \"vite --mode electron\" \"electron .\"",
    "electron:build": "vite build --mode electron && electron-builder",
    "electron:build:all": "vite build --mode electron && electron-builder -mwl",
    "build:capacitor": "vite build --mode capacitor"
  },
  "dependencies": {
    "@capacitor/android": "^8.2.0",
    "@capacitor/cli": "^8.2.0",
    "@capacitor/core": "^8.2.0",
    "@capacitor/status-bar": "^8.0.1",
    "@element-plus/icons-vue": "^2.3.1",
    "@vueuse/core": "^13.5.0",
    "@vueuse/head": "^2.0.0",
    "aieditor": "^1.4.0",
    "axios": "^1.10.0",
    "disable-devtool": "^0.3.9",
    "element-plus": "^2.10.2",
    "nanoid": "^5.1.5",
    "pinia": "^3.0.1",
    "pinia-plugin-persistedstate": "^4.4.1",
    "vue": "^3.5.13",
    "vue-router": "^4.5.0"
  },
  "devDependencies": {
    "@vitejs/plugin-vue": "^5.2.3",
    "@vue/test-utils": "^2.4.6",
    "concurrently": "^8.2.2",
    "cross-env": "^7.0.3",
    "electron": "^28.3.3",
    "electron-builder": "^24.13.3",
    "electron-updater": "^6.8.3",
    "fast-glob": "^3.3.3",
    "javascript-obfuscator": "^4.2.2",
    "jsdom": "^25.0.0",
    "sass-embedded": "^1.89.2",
    "unplugin-auto-import": "^19.3.0",
    "unplugin-element-plus": "^0.10.0",
    "unplugin-vue-components": "^28.8.0",
    "vite": "^6.2.4",
    "vite-plugin-pwa": "^1.2.0",
    "vite-plugin-vue-devtools": "^7.7.2",
    "vitest": "^3.0.0",
    "wait-on": "^7.2.0"
  }
}
