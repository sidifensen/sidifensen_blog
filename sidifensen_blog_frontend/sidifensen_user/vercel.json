{
  "framework": "vue",
  "buildCommand": "vp build",
  "outputDirectory": "dist",
  "devCommand": "vp dev",
  "installCommand": "npm install",
  "headers": [
    {
      "source": "/(.*)",
      "headers": [
        {
          "key": "X-Content-Type-Options",
          "value": "nosniff"
        },
        {
          "key": "X-Frame-Options",
          "value": "DENY"
        }
      ]
    }
  ],
  "rewrites": [
    {
      "source": "/api/:path*",
      "destination": "https://api.sidifensen.com/:path*"
    }
  ]
}
